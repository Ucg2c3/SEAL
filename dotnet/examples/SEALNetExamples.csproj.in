<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <Authors>Microsoft Research</Authors>
    <Company>Microsoft Corporation</Company>
    <Copyright>© Microsoft Corporation. All rights reserved.</Copyright>
    <Description>.NET wrapper examples for Microsoft SEAL</Description>
  </PropertyGroup>

  <PropertyGroup>
    <PlatformTarget>AnyCPU</PlatformTarget>
  </PropertyGroup>

  <PropertyGroup>
    <OutputPath>@CMAKE_RUNTIME_OUTPUT_DIRECTORY@/dotnet/$(Configuration)</OutputPath>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(ProjectDir)../src/SEALNet.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <!-- The library directory is set by CMake for Debug and Release configurations -->
    <SealcOutDir Condition="'$(Configuration)'=='Release'">@CMAKE_LIBRARY_OUTPUT_DIRECTORY_RELEASE@</SealcOutDir>
    <SealcOutDir Condition="'$(Configuration)'=='Debug'">@CMAKE_LIBRARY_OUTPUT_DIRECTORY_DEBUG@</SealcOutDir>
    <SealcOutDir Condition="'$(SealcOutDir)'==''">@CMAKE_LIBRARY_OUTPUT_DIRECTORY_RELEASE@</SealcOutDir>
  
    <!-- The filename pattern depends on the OS -->
    <SealcPattern Condition="$([MSBuild]::IsOsPlatform(Windows))">sealc.dll</SealcPattern>
    <SealcPattern Condition="$([MSBuild]::IsOsPlatform(Linux))">libsealc.so*</SealcPattern>
    <SealcPattern Condition="$([MSBuild]::IsOsPlatform(OSX))">libsealc*.dylib</SealcPattern>
  
    <!-- Portable separator for subdirectories -->
    <DS>$([System.IO.Path]::DirectorySeparatorChar)</DS>
  </PropertyGroup>

  <!-- Include the native library -->
  <ItemGroup>
    <SEALCBinaryFiles Include="$(SealcOutDir)$(DS)$(SealcPattern)" />
  </ItemGroup>

  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <Copy SourceFiles="@(SEALCBinaryFiles)" DestinationFolder="$(TargetDir)" />
  </Target>

  <ItemGroup>
    <Compile Include="@CMAKE_CURRENT_SOURCE_DIR@/dotnet/examples/**/*.cs" />
  </ItemGroup>
</Project>
